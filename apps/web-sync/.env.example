# Supabase (Project Settings -> Database, e API)
DATABASE_URL=
DIRECT_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Mercado Pago (Painel de desenvolvedores -> sua aplicacao -> Credenciais)
MERCADOPAGO_ACCESS_TOKEN=
# Webhooks -> "Assinatura secreta" mostrada ao configurar o webhook
MERCADOPAGO_WEBHOOK_SECRET=
# URL publica desta API + /api/webhooks/mercadopago (preenchida depois do 1o deploy)
