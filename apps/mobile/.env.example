EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_SENTRY_DSN=
# AdMob: app-level IDs go in app.config.ts's plugin config (read at build/prebuild
# time, not from EXPO_PUBLIC_* at runtime); ad UNIT ids below are read at runtime.
EXPO_PUBLIC_ADMOB_APP_ID_ANDROID=
EXPO_PUBLIC_ADMOB_APP_ID_IOS=
EXPO_PUBLIC_ADMOB_BANNER_ID_ANDROID=
EXPO_PUBLIC_ADMOB_BANNER_ID_IOS=
EXPO_PUBLIC_REVENUECAT_KEY_ANDROID=
EXPO_PUBLIC_REVENUECAT_KEY_IOS=
# apps/web-sync deployed URL (e.g. https://noazul-seven.vercel.app) — powers
# login por e-mail + pagamento direto (Pix/boleto/cartão) no paywall.
EXPO_PUBLIC_SYNC_API_URL=
# Supabase Project Settings -> API: Project URL, and the "publishable" key
# (sb_publishable_...) — never the secret/service-role key here, this ships to devices.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
